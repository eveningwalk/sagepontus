# 복사: cp .env.example .env 후 값을 채우세요 (.env는 Git에 올리지 않음)
DJANGO_SECRET_KEY=

# 프로덕션(Cloud Run 등): DJANGO_DEBUG=0 권장. 미설정 시 True(로컬 기본).
# DJANGO_DEBUG=0

# DB: 비우면 로컬 SQLite(db.sqlite3). Cloud Run 프로덕션에서는 반드시 아래를 설정(비우면 컨테이너마다 빈 SQLite → 데이터 유실).
# Supabase → Project Settings → Database → Connection string (URI), Transaction pooler 권장 시 포트 6543
# 예: postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
# DATABASE_URL=

# Hugging Face Inference (프롬프트 생성): Router API는 유효한 토큰이 필요합니다. 비우면 401 Unauthorized.
# 이 파일을 프로젝트 루트에 .env 로 복사한 뒤 값을 채우세요.
# Docker Compose: docker-compose.yml 이 아래 변수를 컨테이너로 넘깁니다(루트 .env 를 읽어 치환).
HF_TOKEN=
# (또는 대안) HUGGINGFACE_HUB_TOKEN=
# 모델 덮어쓰기(선택): manifest 의 model 대신 사용
# HF_MODEL_ID=
# 비우면 Hub가 모델별 Inference Provider를 고름(auto). hf-inference 는 해당 라우트 전용
# HF_INFERENCE_PROVIDER=

# CSRF 403 방지: 접속하는 주소와 동일한 스킴+호스트+포트 (쉼표 구분)
# 예: http://192.168.0.5:8000 또는 https://your.domain
# settings.py 에 *.sagepontus.com(demo.sagepontus.com 등) ALLOWED_HOSTS 가 기본 포함됨.
# CSRF_TRUSTED_ORIGINS 를 비우면 demo.sagepontus.com http/https 도 자동 보강됨. 다른 서브도메인은 여기에 명시.
# 로컬 runserver: DEBUG=True 이면 127.0.0.1·localhost 가 항상 허용됨. 배포용 호스트만 넣어도 로컬 접속 가능.
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,your.domain
# CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# ngrok: ALLOWED_HOSTS 는 DJANGO_ALLOW_NGROK=1 로 처리 가능. CSRF 는 브라우저 Origin(보통 https) 한 줄 필요
# DJANGO_ALLOW_NGROK=1
# DJANGO_NGROK_ORIGIN=https://your-subdomain.ngrok-free.app

# 공개 데모 /demo/ (프로덕션에서는 0 권장)
# DEMO_ENABLED=1
# DEMO_USER_USERNAME=demo_gov_evaluator
# 데모 추천 도메인(Category.name, 기본 startup)
# DEMO_DOMAIN_CATEGORY=startup
