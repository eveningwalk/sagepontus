{
  "manifest_version": 3,
  "name": "Sage Pontus — PT Red Flag Alert",
  "version": "0.2.0",
  "description": "AI-powered Red Flag screening for Physical Therapists. Paste SOAP notes to detect clinical warning signs instantly.",

  "action": {
    "default_title": "PT Red Flag Alert",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage",
    "clipboardRead",
    "clipboardWrite",
    "scripting",
    "activeTab"
  ],

  "host_permissions": [
    "https://sagepontus-284182376290.us-east4.run.app/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
